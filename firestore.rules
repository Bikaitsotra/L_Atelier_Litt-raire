rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Global Helpers Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'johnbikaitsotra@gmail.com';
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email.lower() == email.lower();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validation - Users collection
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'displayName', 'penName', 'createdAt'])
        && data.keys().size() <= 6
        && data.email is string && data.email.size() > 3 && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && data.penName is string && data.penName.size() > 0 && data.penName.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 60;
    }

    // Entity Validation - Profiles collection
    function isValidProfile(data) {
      return data.keys().hasAll(['email', 'displayName', 'penName', 'bio', 'avatarUrl'])
        && data.keys().size() <= 10
        && data.email is string && data.email.size() > 3 && data.email.size() <= 200
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && data.penName is string && data.penName.size() > 0 && data.penName.size() <= 100
        && data.bio is string && data.bio.size() <= 1000
        && data.avatarUrl is string && data.avatarUrl.size() <= 1000
        && (!data.keys().hasAny(['geminiApiKey']) || (data.geminiApiKey is string && data.geminiApiKey.size() <= 150));
    }

    // Entity Validation - Writings collection
    function isValidWriting(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'userEmail', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 12
        && data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 500000
        && data.userEmail is string && data.userEmail.size() <= 200
        && data.createdAt is string && data.createdAt.size() <= 60
        && data.updatedAt is string && data.updatedAt.size() <= 60;
    }

    // Entity Validation - Versions collection
    function isValidVersion(data) {
      return data.keys().hasAll(['id', 'writingId', 'title', 'content', 'savedAt', 'type', 'label'])
        && data.keys().size() <= 8
        && data.id is string && data.id.size() <= 128
        && data.writingId is string && data.writingId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 500000
        && data.savedAt is string && data.savedAt.size() <= 60
        && data.type is string && (data.type == 'auto' || data.type == 'manual')
        && data.label is string && data.label.size() <= 100;
    }

    // Entity Validation - ProductivityDay collection
    function isValidProductivity(data) {
      return data.keys().hasAll(['date', 'wordsWritten', 'minutesSpent', 'userEmail'])
        && data.keys().size() <= 5
        && data.date is string && data.date.size() <= 20
        && data.wordsWritten is int && data.wordsWritten >= 0
        && data.minutesSpent is int && data.minutesSpent >= 0
        && data.userEmail is string && data.userEmail.size() <= 200;
    }

    // Entity Validation - PrivateMessage collection
    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'senderEmail', 'receiverEmail', 'content', 'createdAt'])
        && data.keys().size() <= 6
        && data.id is string && data.id.size() <= 128
        && data.senderEmail is string && data.senderEmail.size() <= 200
        && data.receiverEmail is string && data.receiverEmail.size() <= 200
        && data.content is string && data.content.size() <= 10000
        && data.createdAt is string && data.createdAt.size() <= 60;
    }

    // --- COLLECTION RULES MATCHES ---

    // 1. Users collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) 
                    && isValidUser(incoming())
                    && incoming().email == existing().email; // Email is immutable
      allow delete: if isAdmin();
    }

    // 2. Profiles collection
    match /profiles/{profileId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && (isOwner(incoming().email) || isAdmin()) && isValidProfile(incoming());
      allow update: if isSignedIn() && (isOwner(existing().email) || isAdmin()) 
                    && isValidProfile(incoming())
                    && incoming().email == existing().email; // Email is immutable
      allow delete: if isAdmin();
    }

    // 3. Writings collection
    match /writings/{writingId} {
      allow get: if isSignedIn() && (isOwner(existing().userEmail) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userEmail) || isAdmin());
      allow create: if isSignedIn() && (isOwner(incoming().userEmail) || isAdmin()) && isValidWriting(incoming());
      allow update: if isSignedIn() && (isOwner(existing().userEmail) || isAdmin()) 
                    && isValidWriting(incoming())
                    && incoming().userEmail == existing().userEmail; // Owner is immutable
      allow delete: if isSignedIn() && (isOwner(existing().userEmail) || isAdmin());
    }

    // 4. Versions collection - Derives access from parent writing (Pillar 1: Relational Sync Master Gate)
    match /versions/{versionId} {
      allow get: if isSignedIn() && (
        isOwner(get(/databases/$(database)/documents/writings/$(existing().writingId)).data.userEmail) || isAdmin()
      );
      allow list: if isSignedIn() && (
        // Client filtering is securely validated against the requested writing record
        isOwner(get(/databases/$(database)/documents/writings/$(resource.data.writingId)).data.userEmail) || isAdmin()
      );
      allow create: if isSignedIn() && isValidVersion(incoming()) && (
        isOwner(get(/databases/$(database)/documents/writings/$(incoming().writingId)).data.userEmail) || isAdmin()
      );
      allow update: if isSignedIn() && isValidVersion(incoming()) && (
        isOwner(get(/databases/$(database)/documents/writings/$(existing().writingId)).data.userEmail) || isAdmin()
      ) && incoming().writingId == existing().writingId;
      allow delete: if isSignedIn() && (
        isOwner(get(/databases/$(database)/documents/writings/$(existing().writingId)).data.userEmail) || isAdmin()
      );
    }

    // 5. ProductivityDays collection
    match /productivity/{dayId} {
      allow get: if isSignedIn() && (isOwner(existing().userEmail) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userEmail) || isAdmin());
      allow create: if isSignedIn() && (isOwner(incoming().userEmail) || isAdmin()) && isValidProductivity(incoming());
      allow update: if isSignedIn() && (isOwner(existing().userEmail) || isAdmin()) 
                    && isValidProductivity(incoming())
                    && incoming().userEmail == existing().userEmail;
      allow delete: if isAdmin();
    }
    
    // 6. Private messages collection
    match /messages/{messageId} {
      allow get: if isSignedIn() && (isOwner(existing().senderEmail) || isOwner(existing().receiverEmail) || isAdmin());
      allow list: if isSignedIn() && (resource.data.senderEmail == request.auth.token.email || resource.data.receiverEmail == request.auth.token.email || isAdmin());
      allow create: if isSignedIn() && (isOwner(incoming().senderEmail) || isAdmin()) && isValidMessage(incoming());
      allow update: if isSignedIn() && (isOwner(existing().senderEmail) || isAdmin())
                    && isValidMessage(incoming())
                    && incoming().senderEmail == existing().senderEmail; // Sender is immutable
      allow delete: if isAdmin();
    }
  }
}
